# Application
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379/0
JOB_TTL_SECONDS=3600         # how long to keep job results

# Storage — local dev uses filesystem, prod uses /tmp
STORAGE_BACKEND=local        # local | s3 (future)
UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs
MAX_UPLOAD_SIZE_MB=100

# ML Models
WAV2LIP_WEIGHTS=./app/ml/weights/wav2lip_gan.pth
FACE_DETECTOR_WEIGHTS=./app/ml/weights/s3fd.pth
WHISPER_MODEL_SIZE=base      # tiny | base | small | medium
DEVICE=cpu                   # cpu | cuda

# Performance
WAV2LIP_BATCH_SIZE=128       # reduce to 32 if OOM
INFERENCE_TIMEOUT_SECONDS=300

# CORS — comma separated origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
