# Frontend environment variables
# Copy this file to .env.local and update values as needed

# Backend API URL - must match where the FastAPI server is running
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application name - used in metadata and UI
NEXT_PUBLIC_APP_NAME=PhonemeSync

# Optional: Polling interval (milliseconds) - default 2000
# NEXT_PUBLIC_POLL_INTERVAL_MS=2000

# Optional: Maximum video file size in MB - default 50
# NEXT_PUBLIC_MAX_VIDEO_SIZE_MB=50

# Optional: Maximum audio file size in MB - default 20
# NEXT_PUBLIC_MAX_AUDIO_SIZE_MB=20
